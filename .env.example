# ── Copy this to .env and fill in your local values ─────────────
# .env is gitignored — never commit it

# ── AWS ──────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=xxxxxxxxxxxx
# Local dev: use a named profile from ~/.aws/credentials
AWS_PROFILE=am-copilot-dev

# ── Database (local dev uses Docker PostgreSQL) ───────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/amcopilot_dev

# ── CTM sandbox ──────────────────────────────────────────────────
CTM_API_KEY=your_ctm_api_key_here
CTM_ACCOUNT_ID=your_ctm_sandbox_account_id
CTM_WEBHOOK_SECRET=your_ctm_webhook_secret

# ── Bedrock ──────────────────────────────────────────────────────
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20251001-v1:0

# ── SQS (local dev can use LocalStack or real AWS) ───────────────
EVALUATION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/xxxxxxxxxxxx/am-copilot-evaluation

# ── Auth ─────────────────────────────────────────────────────────
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App config ───────────────────────────────────────────────────
RUBRIC_VERSION=rubric-v1
PROMPT_VERSION=prompt-v1
COACHING_QUEUE_THRESHOLD=70
LOW_CONFIDENCE_THRESHOLD=0.65
COMPLIANCE_OVERRIDE_ENABLED=false

# ── Environment ──────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG
